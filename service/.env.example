# =============================================================================
# agent-wiki server config
# =============================================================================
# Copy this file to .env and fill in real values. Variables without a default
# are required.

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

PORT=3045

# Public-facing base URL where this service is reachable. Used for OAuth
# callbacks — must match the redirect URI configured in Google Cloud.
BASE_URL=https://example.com

# Subpath the app is mounted at behind a reverse proxy. Use "" for the
# domain root, or e.g. "/wiki".
PATH_PREFIX=/wiki

# -----------------------------------------------------------------------------
# Sessions
# -----------------------------------------------------------------------------

# Stable random string. Rotating it invalidates all sessions.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (https://console.cloud.google.com)
# -----------------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Authorized redirect URI = ${BASE_URL}${PATH_PREFIX}/auth/google/callback

# Comma-separated allowlist of Google emails permitted to sign in.
ALLOWED_EMAILS=you@example.com

# -----------------------------------------------------------------------------
# Filesystem layout
# -----------------------------------------------------------------------------

# Parent dir containing the sibling projects whose AGENTS.md files this wiki
# indexes and sweeps. REQUIRED — no default, since this is install-specific.
PROJECTS_ROOT=/path/to/your/projects

# Optional overrides — defaults are repo-relative and usually correct.
# INDEX_DIR=/absolute/path/to/agent-wiki/index
# UI_DIST=/absolute/path/to/agent-wiki/ui/dist

# -----------------------------------------------------------------------------
# Sweeper (only needed if you run `npm run sweeper`)
# -----------------------------------------------------------------------------

# Anthropic API key used by the sweeper to call Claude. Required for sweeps.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Override the model used by the sweeper (default: claude-opus-4-7).
# SWEEPER_MODEL=claude-opus-4-7

# Override the agent identifier appended to last_updated_by in swept files.
# SWEEPER_AGENT=agent:sweeper-claude-opus-4-7
