# agent-wiki server config

# Network
PORT=3045
BASE_URL=https://secorp.net
PATH_PREFIX=/wiki

# Sessions (must be a stable random string; rotating it invalidates all sessions)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Authorized redirect URI = ${BASE_URL}${PATH_PREFIX}/auth/google/callback

# Comma-separated allowlist of Google emails that can sign in.
ALLOWED_EMAILS=secorp@gmail.com

# Where the indexer outputs live and where the source AGENTS.md files live.
# Defaults match the standard layout under ~/termag/projects/.
INDEX_DIR=/home/secorp/termag/projects/agent-wiki/index
PROJECTS_ROOT=/home/secorp/termag/projects

# Frontend dist (built by the ui/ package). Backend serves this as static at PATH_PREFIX.
UI_DIST=/home/secorp/termag/projects/agent-wiki/ui/dist
