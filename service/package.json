{
  "name": "agent-wiki-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "agent-wiki backend: indexer + read-only HTTP API + UI host.",
  "scripts": {
    "build": "tsc",
    "indexer": "tsx src/indexer/cli.ts",
    "indexer:built": "node dist/indexer/cli.js",
    "server": "tsx src/server/index.ts",
    "server:built": "node dist/server/index.js",
    "sweeper": "tsx src/sweeper/cli.ts",
    "sweeper:built": "node dist/sweeper/cli.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "gray-matter": "^4.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.0",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/session-file-store": "^1.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
